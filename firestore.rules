rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Funções auxiliares ────────────────────────────────────────────────────

    function autenticado() {
      return request.auth != null;
    }

    // Admin bootstrap por e-mail verificado — sem leitura adicional ao Firestore.
    // Garante que benone.marcos@gmail.com tem sempre acesso mesmo sem documento.
    function isAdminEmail() {
      return autenticado()
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'benone.marcos@gmail.com';
    }

    function existeUtilizador() {
      return exists(/databases/$(database)/documents/utilizadores/$(request.auth.uid));
    }

    function dadosUtilizador() {
      return get(/databases/$(database)/documents/utilizadores/$(request.auth.uid)).data;
    }

    // Admin: e-mail bootstrap OU papel 'admin' no Firestore
    function isAdmin() {
      return isAdminEmail()
        || (autenticado() && existeUtilizador() && dadosUtilizador().papel == 'admin');
    }

    // Aprovado: admin sempre aprovado; demais precisam de estado == 'aprovado'
    function isAprovado() {
      return isAdmin()
        || (autenticado() && existeUtilizador() && dadosUtilizador().estado == 'aprovado');
    }

    // Papel do utilizador corrente (string); 'pendente' se não tiver documento
    function papelAtual() {
      return autenticado() && existeUtilizador()
        ? dadosUtilizador().papel
        : 'pendente';
    }

    // Admin ou coordenador — gestão de operações e leitura de dados sensíveis
    function gestaoPapeis() {
      return isAprovado() && papelAtual() in ['admin', 'coordenador'];
    }

    // Equipa operacional (exclui beneficiários) — Eixo 1/2
    function equipa() {
      return isAprovado()
        && papelAtual() in ['admin', 'coordenador', 'voluntario', 'profissional'];
    }


    // ─── Formulários públicos (acesso sem autenticação) ────────────────────────
    // Qualquer visitante web pode submeter; só a gestão lê.

    match /beneficiarios/{doc} {
      allow create: if true;
      allow read:   if gestaoPapeis();
      allow update, delete: if isAdmin();
    }

    match /voluntarios/{doc} {
      allow create: if true;
      allow read:   if gestaoPapeis();
      allow update, delete: if isAdmin();
    }

    match /contactos/{doc} {
      allow create: if true;
      allow read:   if gestaoPapeis();
      allow update, delete: if isAdmin();
    }

    match /newsletter_subscriptions/{doc} {
      allow create: if true;
      allow read:   if gestaoPapeis();
      allow update, delete: if isAdmin();
    }


    // ─── Eixo 1 — Mão que Ampara ──────────────────────────────────────────────

    match /campanhas/{doc} {
      allow create, read: if equipa();
      allow update, delete: if gestaoPapeis();
    }

    match /stock/{doc} {
      allow create, read: if equipa();
      allow update, delete: if gestaoPapeis();
    }

    match /distribuicoes/{doc} {
      allow create, read: if equipa();
      allow update, delete: if gestaoPapeis();
    }


    // ─── Eixo 2 — Coração que Cuida ───────────────────────────────────────────

    match /profissionaisVoluntarios/{doc} {
      allow create: if equipa();
      // Profissionais podem ver os próprios registos; gestão vê todos
      allow read:   if gestaoPapeis() || papelAtual() == 'profissional';
      allow update, delete: if isAdmin();
    }

    match /referencias/{doc} {
      allow create: if equipa();
      allow read:   if gestaoPapeis() || papelAtual() == 'profissional';
      allow update, delete: if gestaoPapeis();
    }

    match /accoesPrevcao/{doc} {
      allow create, read: if equipa();
      allow update, delete: if gestaoPapeis();
    }


    // ─── Eixo 3 — Ponte de Esperança (dados confidenciais) ────────────────────

    match /necessidades/{doc} {
      allow create, read: if gestaoPapeis();
      allow update, delete: if isAdmin();
    }

    match /doacoesEspecificas/{doc} {
      allow create, read: if gestaoPapeis();
      allow update, delete: if isAdmin();
    }


    // ─── Pedidos de apoio (beneficiários autenticados) ────────────────────────
    // O beneficiário cria e consulta os SEUS pedidos; a gestão vê todos.

    match /pedidosApoio/{doc} {
      allow create: if isAprovado()
        && request.resource.data.uid == request.auth.uid;
      allow read:   if gestaoPapeis()
        || (isAprovado() && resource.data.uid == request.auth.uid);
      allow update: if gestaoPapeis();
      allow delete: if isAdmin();
    }


    // ─── Gestão de utilizadores ────────────────────────────────────────────────

    match /utilizadores/{uid} {
      // Qualquer utilizador autenticado lê/cria o SEU próprio documento
      allow get:    if autenticado() && (request.auth.uid == uid || isAdmin());
      allow list:   if isAdmin();
      allow create: if autenticado() && request.auth.uid == uid;
      // Utilizador pode actualizar o próprio perfil mas NÃO pode alterar
      // papel / estado / campos de aprovação — só o admin pode
      allow update: if isAdmin()
        || (autenticado() && request.auth.uid == uid
            && !request.resource.data.diff(resource.data)
                .affectedKeys()
                .hasAny(['papel', 'estado', 'aprovadoPor', 'aprovadoEm']));
      allow delete: if isAdmin();
    }


    // ─── Colecção legada de admins (compatibilidade retroactiva) ──────────────

    match /admins/{uid} {
      allow read:  if autenticado() && request.auth.uid == uid;
      allow write: if false;
    }


    // ─── Bloquear tudo o resto por defeito ────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
